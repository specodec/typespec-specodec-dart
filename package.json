{
  "name": "@specodec/typespec-emitter-dart",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@specodec/typespec-emitter-core": "0.1.0"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.11.0",
    "typescript": "^5.8.0"
  },
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-emitter-dart": {
        "type": "object",
        "properties": {
          "emitter-output-dir": {
            "type": "string"
          },
          "ignore-reserved-keywords": {
            "type": "boolean"
          }
        },
        "required": [
          "emitter-output-dir"
        ]
      }
    }
  }
}
